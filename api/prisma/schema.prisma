generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  plan      Plan     @default(b2c)
  tenantId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments  Payment[]
  results   TestResult[]
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  plan      Plan     @default(b2b)
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
}

model Payment {
  id             String        @id @default(uuid())
  userId         String?
  sessionId      String        @unique
  mpPaymentId    String?       @unique
  mpPreferenceId String?
  status         PaymentStatus @default(pending)
  plan           Plan
  amountArs      Decimal?
  email          String?
  userName       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user     User?       @relation(fields: [userId], references: [id])
  result   TestResult?
}

model TestResult {
  id                String    @id @default(uuid())
  sessionId         String    @unique
  userId            String?
  paymentId         String?   @unique
  hollandCode       String
  riasecScores      Json
  perfilTitulo      String
  perfilDescripcion String
  fortalezas        Json
  carreras          Json
  fraseMotivadora   String
  rawResult         Json
  emailSentAt       DateTime?
  createdAt         DateTime  @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])
}

model SessionState {
  id            String   @id @default(uuid())
  sessionId     String   @unique
  questionCount Int
  phase         String
  updatedAt     DateTime @updatedAt
}

enum Plan {
  b2c
  b2b
  b2b2c
}

enum PaymentStatus {
  pending
  approved
  rejected
  cancelled
  in_process
}
