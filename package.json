{
  "name": "voctest-platform",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:web": "turbo dev --filter=web",
    "dev:api": "turbo dev --filter=api",
    "db:migrate": "cd api && pnpm prisma migrate dev",
    "db:generate": "cd api && pnpm prisma generate",
    "db:studio": "cd api && pnpm prisma studio"
  },
  "devDependencies": {
    "turbo": "latest"
  }
}
