      "id": "webhook-main-001",
      "name": "[Webhook] Entrada chat",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 300],
      "webhookId": "voctest-chat-v1"
    },
    {
      "parameters": {
        "rules": {
          "values": [
