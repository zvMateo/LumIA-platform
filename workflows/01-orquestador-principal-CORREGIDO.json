    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://gmn8nwebhook.goodapps.space/webhook/voctest/chat-handler",
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify($json.body) }}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "afc90c80-bbc5-4164-b825-a851d16c69f4",
      "name": "[HTTP] Llamar Workflow Chat",
