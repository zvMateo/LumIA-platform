                    "rightValue": true,
                    "operator": {
                      "type": "boolean",
                      "operation": "true"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "Status Check"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra",
          "renameFallbackOutput": "Chat Message"
        }
      },
      "id": "switch-main-001",
      "name": "[Switch] Tipo de operación",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.4,
      "position": [220, 300]
    },
    {
      "parameters": {
        "operation": "get",
        "propertyName": "value",
        "key": "={{ 'voc:result:' + $json.body.sessionId }}",
        "options": {}
      },
      "id": "redis-get-result-001",
      "name": "[Redis] GET Resultado",
      "type": "n8n-nodes-base.redis",
      "typeVersion": 1,
      "position": [460, 480],
      "credentials": {
        "redis": {
          "id": "kC0Bfi0yQOAqlL1I",
          "name": "Redis_GoodApps"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "try {\n  const raw = $input.item.json.value;\n  const sessionId = $('[Webhook] Entrada chat').item.json.body.sessionId;\n  \n  if (!raw) {\n    return [{ json: {\n      ready: false,\n      sessionId,\n      message: 'Analizando tu perfil vocacional...'\n    } }];\n  }\n  \n  const resultado = typeof raw === 'string' ? JSON.parse(raw) : raw;\n  \n  return [{ json: {\n    ready: true,\n    sessionId: resultado.sessionId,\n    hollandCode: resultado.hollandCode,\n    perfilTitulo: resultado.perfilTitulo,\n    perfilDescripcion: resultado.perfilDescripcion,\n    fortalezas: resultado.fortalezas,\n    areasDesarrollo: resultado.areasDesarrollo,\n    carreras: resultado.carreras,\n    riasecScores: resultado.riasecScores,\n    consejosEstudio: resultado.consejosEstudio,\n    fraseMotivadora: resultado.fraseMotivadora,\n    generadoEn: resultado.generadoEn\n  } }];\n} catch(e) {\n  return [{ json: {\n    ready: false,\n    sessionId: $('[Webhook] Entrada chat').item.json.body.sessionId,\n    message: 'Procesando tu resultado...'\n  } }];\n}"
      },
      "id": "code-format-status-001",
      "name": "[Code] Formatear respuesta status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 480]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}",
        "options": {}
