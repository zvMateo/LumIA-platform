# Variables de Entorno para Workflows n8n - VocTest IA
# Copiar este archivo a .env y completar con tus valores

# =============================================
# CONFIGURACIÓN DE REDIS
# =============================================

# Host de Redis (ej: redis://localhost:6379)
REDIS_HOST=redis://localhost:6379

# Puerto de Redis
REDIS_PORT=6379

# Contraseña de Redis (si tiene)
REDIS_PASSWORD=

# Número de base de datos de Redis (default: 0)
REDIS_DB=0

# =============================================
# CONFIGURACIÓN DE OPENAI
# =============================================

# API Key de OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo a usar para el agente conversacional (default: gpt-4o)
OPENAI_MODEL_AGENT=gpt-4o

# Modelo a usar para el análisis (default: gpt-4o)
OPENAI_MODEL_ANALYSIS=gpt-4o

# Máximo de tokens por respuesta (default: 1800)
OPENAI_MAX_TOKENS=1800

# Temperatura del modelo (0.0 - 1.0, default: 0.65)
OPENAI_TEMPERATURE=0.65

# =============================================
# CONFIGURACIÓN DE GMAIL/EMAIL
# =============================================

# Email del remitente
EMAIL_FROM=testvocacional@gmail.com

# Nombre del remitente
EMAIL_FROM_NAME=VocTest IA

# Configuración SMTP (si usas SMTP en lugar de Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=testvocacional@gmail.com
SMTP_PASS=tu-contraseña-de-aplicación

# =============================================
# CONFIGURACIÓN DE SESIONES
# =============================================

# TTL para sesiones activas (en segundos, default: 7200 = 2 horas)
SESSION_TTL_ACTIVE=7200

# TTL para sesiones completadas (en segundos, default: 86400 = 24 horas)
SESSION_TTL_COMPLETE=86400

# TTL para resultados (en segundos, default: 86400 = 24 horas)
RESULT_TTL=86400

# Máximo de preguntas por test (default: 25)
MAX_QUESTIONS=25

# =============================================
# CONFIGURACIÓN DE WEBHOOKS
# =============================================

# URL base de tu instancia n8n (sin / al final)
N8N_BASE_URL=https://gmn8nwebhook.goodapps.space

# Path del webhook principal de chat
CHAT_WEBHOOK_PATH=/webhook/voctest/chat

# Path del webhook de análisis
ANALYSIS_WEBHOOK_PATH=/webhook/voctest/analysis

# Path del webhook de chat handler
CHAT_HANDLER_WEBHOOK_PATH=/webhook/voctest/chat-handler

# =============================================
# CONFIGURACIÓN DE DESARROLLO
# =============================================

# Modo debug (true/false)
DEBUG=false

# Nivel de logging (error, warn, info, debug)
LOG_LEVEL=info

# Puerto del servidor n8n (default: 5678)
N8N_PORT=5678

# =============================================
# CREDENCIALES (para documentación - configurar en n8n UI)
# =============================================

# Redis credential ID (no modificar si usas el mismo nombre)
REDIS_CREDENTIAL_ID=kC0Bfi0yQOAqlL1I
REDIS_CREDENTIAL_NAME=Redis_GoodApps

# OpenAI credential ID (no modificar si usas el mismo nombre)
OPENAI_CREDENTIAL_ID=LVIDq0T0z4cISnRM
OPENAI_CREDENTIAL_NAME=OpenAi GoodApps

# Gmail credential ID (no modificar si usas el mismo nombre)
GMAIL_CREDENTIAL_ID=OiZEeFUODmvbFi12
GMAIL_CREDENTIAL_NAME=Gmail account

# =============================================
# INSTRUCCIONES DE USO
# =============================================

# 1. Copia este archivo a .env: cp env.example .env
# 2. Completa las variables con tus valores
# 3. En n8n, importa los workflows en orden: 01, 02, 03
# 4. Configura las credenciales en n8n UI con los IDs de arriba
# 5. Actualiza las URLs en los nodos HTTP Request según tu instancia
# 6. Activa los workflows

# Para desarrollo local, puedes usar:
# - Redis: docker run -d -p 6379:6379 redis:alpine
# - n8n: docker run -d -p 5678:5678 -v ~/.n8n:/home/node/.n8n n8nio/n8n

# =============================================
# URLS FINALES PARA EL FRONTEND
# =============================================

# URL principal que debe usar tu backend NestJS:
# POST ${N8N_BASE_URL}${CHAT_WEBHOOK_PATH}

# Ejemplo completo:
# POST https://gmn8nwebhook.goodapps.space/webhook/voctest/chat
