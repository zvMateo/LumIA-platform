  "instructions": {
    "es": {
      "title": "Guía de Configuración Rápida",
      "steps": [
        {
          "step": 1,
          "title": "Importar Workflows",
          "description": "Importa los 3 archivos JSON en orden",
          "details": [
            "1. Ve a Workflows → Importar",
            "2. Importa 01-orquestador-principal.json",
            "3. Importa 02-chat-conversacional.json",
            "4. Importa 03-analisis-informe.json",
            "5. Activa cada workflow (switch azul)"
          ]
        },
        {
          "step": 2,
          "title": "Configurar Credenciales",
          "description": "Configura las 3 credenciales necesarias",
          "details": [
            "1. Ve a Credentials",
            "2. Crea credencial Redis con ID: kC0Bfi0yQOAqlL1I",
            "3. Crea credencial OpenAI con ID: LVIDq0T0z4cISnRM",
            "4. Crea credencial Gmail con ID: OiZEeFUODmvbFi12"
          ]
        },
        {
          "step": 3,
          "title": "Actualizar URLs",
          "description": "Actualiza las URLs en los workflows",
          "details": [
            "1. En workflow 01, actualiza nodo HTTP: '[HTTP] Llamar Workflow Chat'",
            "2. En workflow 02, actualiza nodo HTTP: '[HTTP] Llamar análisis'",
            "3. Usa las URLs de tu instancia de n8n"
          ]
        },
        {
          "step": 4,
          "title": "Probar",
          "description": "Prueba el flujo completo",
          "details": [
            "1. Ejecuta: ./test-workflows.sh",
            "2. Revisa que las respuestas sean correctas",
            "3. Verifica que los emails se envíen",
            "4. Confirma que los resultados se guarden"
          ]
        }
      ],
      "urls": {
        "chat": "https://gmn8nwebhook.goodapps.space/webhook/voctest/chat",
        "status": "https://gmn8nwebhook.goodapps.space/webhook/voctest/chat",
