      "active": true,
      "nodes": "Ver archivo: 01-orquestador-principal.json",
      "connections": "Ver archivo: 01-orquestador-principal.json",
      "settings": {
        "saveManualExecutions": true,
        "saveExecutionProgress": true,
        "executionTimeout": 3600
      },
